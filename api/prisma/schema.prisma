generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String             @id @default(uuid())
  email                 String             @unique
  passwordHash          String
  name                  String
  role                  Role               @default(USER)
  audios                Audio[]
  auditedTranscriptions Transcription[]    @relation("TranscriptionAuditor")
  keywordSets           UserKeywordSet[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Audio {
  id              String   @id @default(uuid())
  userId          String
  filePath        String
  transcriptRaw   String?
  extractedDate   String?
  extractedClient String?
  extractedMedium String?
  extractedSubject String?
  status          AudioStatus @default(PENDING)
  hidden          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  auditLogs     AuditLog[]
  transcription Transcription?
}

model KeywordSet {
  id             String           @id @default(uuid())
  name           String
  keywords       Json             // [{ name: string, type: 'String'|'Integer'|'Decimal'|'Date'|'Time'|'Datetime'|'Dropdown', decimals?: number, mask?: string, options?: any[] }]
  webhook        Json?            // { url, method, authType, authToken, authUser, authPass, authHeader, authKey, extraHeaders, bodyTemplate }
  createdAt      DateTime         @default(now())
  transcriptions Transcription[]
  users          UserKeywordSet[]
}

model UserKeywordSet {
  userId       String
  keywordSetId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywordSet   KeywordSet @relation(fields: [keywordSetId], references: [id], onDelete: Cascade)

  @@id([userId, keywordSetId])
}

model Transcription {
  id           String      @id @default(uuid())
  audioId      String      @unique
  audio        Audio       @relation(fields: [audioId], references: [id], onDelete: Cascade)
  fullText     String
  fields       Json        @default("{}")
  keywordSetId String?
  keywordSet   KeywordSet? @relation(fields: [keywordSetId], references: [id])
  auditedAt       DateTime?
  auditedByUserId String?
  auditedBy       User?     @relation("TranscriptionAuditor", fields: [auditedByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorUserId String
  audioId    String
  action     AuditAction
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  audio Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum AudioStatus {
  PENDING
  TRANSCRIBED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE_STRUCTURED_FIELDS
  DELETE
}
